{
	"name": "@dubium/eslint-config",
	"version": "2.0.0-beta.2",
	"type": "module",
	"private": false,
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./common": {
			"types": "./dist/common/index.d.ts",
			"import": "./dist/common/index.js"
		},
		"./common/comments": {
			"types": "./dist/common/comments.d.ts",
			"import": "./dist/common/comments.js"
		},
		"./common/ignores": {
			"types": "./dist/common/ignores.d.ts",
			"import": "./dist/common/ignores.js"
		},
		"./common/javascript": {
			"types": "./dist/common/javascript.d.ts",
			"import": "./dist/common/javascript.js"
		},
		"./common/sorting": {
			"types": "./dist/common/sorting.d.ts",
			"import": "./dist/common/sorting.js"
		},
		"./common/stylistic": {
			"types": "./dist/common/stylistic.d.ts",
			"import": "./dist/common/stylistic.js"
		},
		"./typescript": {
			"types": "./dist/typescript/index.d.ts",
			"import": "./dist/typescript/index.js"
		},
		"./typescript/base": {
			"types": "./dist/typescript/base.d.ts",
			"import": "./dist/typescript/base.js"
		},
		"./typescript/semantic": {
			"types": "./dist/typescript/semantic.d.ts",
			"import": "./dist/typescript/semantic.js"
		},
		"./typescript/sorting": {
			"types": "./dist/typescript/sorting.d.ts",
			"import": "./dist/typescript/sorting.js"
		},
		"./typescript/strict": {
			"types": "./dist/typescript/strict.d.ts",
			"import": "./dist/typescript/strict.js"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.js"
		},
		"./react/core": {
			"types": "./dist/react/core.d.ts",
			"import": "./dist/react/core.js"
		},
		"./react/hooks": {
			"types": "./dist/react/hooks.d.ts",
			"import": "./dist/react/hooks.js"
		},
		"./react/stylistic": {
			"types": "./dist/react/stylistic.d.ts",
			"import": "./dist/react/stylistic.js"
		},
		"./react/recommended": {
			"types": "./dist/react/recommended.d.ts",
			"import": "./dist/react/recommended.js"
		},
		"./react/strict": {
			"types": "./dist/react/strict.d.ts",
			"import": "./dist/react/strict.js"
		},
		"./browser": {
			"types": "./dist/browser/index.d.ts",
			"import": "./dist/browser/index.js"
		},
		"./browser/runtime": {
			"types": "./dist/browser/runtime.d.ts",
			"import": "./dist/browser/runtime.js"
		},
		"./node": {
			"types": "./dist/node/index.d.ts",
			"import": "./dist/node/index.js"
		},
		"./node/runtime": {
			"types": "./dist/node/runtime.d.ts",
			"import": "./dist/node/runtime.js"
		},
		"./vitest": {
			"types": "./dist/vitest/index.d.ts",
			"import": "./dist/vitest/index.js"
		},
		"./vitest/runtime": {
			"types": "./dist/vitest/runtime.d.ts",
			"import": "./dist/vitest/runtime.js"
		},
		"./jest": {
			"types": "./dist/jest/index.d.ts",
			"import": "./dist/jest/index.js"
		},
		"./jest/runtime": {
			"types": "./dist/jest/runtime.d.ts",
			"import": "./dist/jest/runtime.js"
		},
		"./nest": {
			"types": "./dist/nest/index.d.ts",
			"import": "./dist/nest/index.js"
		},
		"./nest/conventions": {
			"types": "./dist/nest/conventions.d.ts",
			"import": "./dist/nest/conventions.js"
		},
		"./nest/recommended": {
			"types": "./dist/nest/recommended.d.ts",
			"import": "./dist/nest/recommended.js"
		},
		"./nest/strict": {
			"types": "./dist/nest/strict.d.ts",
			"import": "./dist/nest/strict.js"
		},
		"./presets": {
			"types": "./dist/presets/index.d.ts",
			"import": "./dist/presets/index.js"
		},
		"./recommended": {
			"types": "./dist/presets/recommended.d.ts",
			"import": "./dist/presets/recommended.js"
		},
		"./recommended-fast": {
			"types": "./dist/presets/recommended-fast.d.ts",
			"import": "./dist/presets/recommended-fast.js"
		},
		"./legacy": {
			"types": "./dist/presets/legacy.d.ts",
			"import": "./dist/presets/legacy.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"README-RU.md",
		"LICENSE"
	],
	"description": "Opinionated ESLint flat config for strict TypeScript, React and NestJS projects.",
	"keywords": [
		"eslint",
		"eslintconfig",
		"flat-config",
		"typescript",
		"react",
		"nestjs",
		"styleguide"
	],
	"homepage": "https://github.com/Dubium-Design-System/eslint-config/",
	"bugs": {
		"url": "https://github.com/Dubium-Design-System/eslint-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Dubium-Design-System/eslint-config.git"
	},
	"author": "https://github.com/DubiumEkb",
	"license": "MIT",
	"scripts": {
		"clean": "rimraf dist *.tgz",
		"build": "tsc -p tsconfig.build.json",
		"prepack": "npm run clean && npm run build && npm run lint",
		"pack:check": "npm pack --dry-run",
		"pack:local": "npm pack",
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:inspect": "npm run build && eslint --inspect-config",
		"version:alpha": "npm version prerelease --preid=alpha",
		"version:beta": "npm version prerelease --preid=beta",
		"version:patch": "npm version patch",
		"version:minor": "npm version minor",
		"version:major": "npm version major",
		"version:major:alpha": "npm version premajor --preid=alpha",
		"version:major:beta": "npm version premajor --preid=beta",
		"publish:alpha": "npm publish --access=public --tag alpha",
		"publish:beta": "npm publish --access=public --tag beta",
		"publish:next": "npm publish --access=public --tag next",
		"publish:release": "npm publish --access=public --tag latest",
		"release:alpha": "npm run version:alpha && npm run publish:alpha",
		"release:beta": "npm run version:beta && npm run publish:beta",
		"release:patch": "npm run version:patch && npm run publish:release",
		"release:minor": "npm run version:minor && npm run publish:release",
		"release:major": "npm run version:major && npm run publish:release",
		"release:major:alpha": "npm run version:major:alpha && npm run publish:alpha",
		"release:major:beta": "npm run version:major:beta && npm run publish:beta",
		"tags": "npm dist-tag ls @dubium/eslint-config"
	},
	"dependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@eslint-react/eslint-plugin": "^5.9.0",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-jest": "^29.15.2",
		"eslint-plugin-n": "^18.1.0",
		"eslint-plugin-perfectionist": "^5.9.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globals": "^17.6.0",
		"typescript-eslint": "^8.61.1"
	},
	"peerDependencies": {
		"eslint": ">=10.5.0 <11",
		"typescript": ">=6.0.3 <7"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=22.13.0"
	}
}
